# krauncher client configuration
# All variables are optional — explicit constructor args take priority.

# API key for authentication (required for task submission)
# CAS_API_KEY=cas_...
CAS_API_KEY=9f95fc2a748303231510842326c3a603b2078fadd7fb31cfab64559ad7487abc

# Broker URL
CAS_BROKER_URL=https://krauncher.com/api

# Task complexity analyzer URL (enables automatic VRAM/tier classification)
CAS_ANALYZER_URL=http://localhost:8008

# E2E encryption for task code (client ↔ worker via relay)
CAS_ENCRYPT=true

# E2E encryption for analyzer requests (client ↔ analyzer)
CAS_ENCRYPT_ANALYZER=true

# Analyzer request timeout (seconds)
CAS_ANALYZER_TIMEOUT=30

# Debug logging
KRAUNCHER_DEBUG=0
